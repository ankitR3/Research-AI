# --- Required ---
# OpenRouter is used for all AI processing (summaries, pain points, competitors)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Serper.dev is used for search (finding official sites, competitors, contact info)
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional (can also be supplied per-request by the frontend) ---
# Discord bot used to post completed reports to a channel
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# CORS: comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Crawler tuning
CRAWLER_MAX_PAGES=8
CRAWLER_TIMEOUT_SECONDS=10
